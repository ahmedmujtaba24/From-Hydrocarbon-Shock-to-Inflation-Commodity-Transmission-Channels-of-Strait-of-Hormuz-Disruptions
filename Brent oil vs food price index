# Method 1: Strict exact date matches
df_strict = pd.merge(df_cpi, df_brent, on='Date', how='inner')
strict_corr = {}
for col in df_cpi.columns:
    if 'YoY' in col:
        strict_corr[col] = df_strict['Brent Crude ($/bbl)'].corr(df_strict[col])

# Method 2: Event-based matching (nearest within 90 days tolerance to line up event milestones)
df_event = pd.merge_asof(df_cpi.sort_values('Parsed_Date'), df_brent.sort_values('Parsed_Date'), 
                         on='Parsed_Date', direction='nearest', tolerance=pd.Timedelta(days=90)).dropna()

event_corr = {}
for col in df_cpi.columns:
    if 'YoY' in col:
        event_corr[col] = df_event['Brent Crude ($/bbl)'].corr(df_event[col])

print("Strict Correlation Matrix:")
print(strict_corr)
print("\nEvent-based Correlation Matrix:")
print(event_corr)

# Create a nice dataframe for visual reporting
corr_df = pd.DataFrame({
    'Strict Date Matching': strict_corr,
    'Event-Based Matching (±90d)': event_corr
})

print("\nCombined DataFrame:")
print(corr_df)

# Plotting the correlation coefficients using the user's requested blue theme
plt.style.use('seaborn-v0_8-whitegrid' if 'seaborn-v0_8-whitegrid' in plt.style.available else 'default')
