12-06-2026	87.37"""

df_cpi = pd.read_csv(io.StringIO(cpi_text), sep="\t")
df_brent = pd.read_csv(io.StringIO(brent_text), sep="\t")

# Clean
df_cpi['Parsed_Date'] = pd.to_datetime(df_cpi['Date'], format='%d-%m-%Y')
for col in df_cpi.columns:
    if 'YoY' in col:
        df_cpi[col] = df_cpi[col].str.rstrip('%').astype('float')

df_brent['Parsed_Date'] = pd.to_datetime(df_brent['Date'], format='%d-%m-%Y')
df_brent['Brent Crude ($/bbl)'] = pd.to_numeric(df_brent['Brent Crude ($/bbl)'], errors='coerce')
df_brent = df_brent.dropna()

# Event-level alignment (nearest match within 90 days to handle different reporting lags of the same event)
df_merged = pd.merge_asof(
    df_cpi.sort_values('Parsed_Date'), 
    df_brent.sort_values('Parsed_Date'), 
    on='Parsed_Date', 
    direction='nearest', 
    tolerance=pd.Timedelta(days=90)
).dropna(subset=['Brent Crude ($/bbl)'])

features = ['Global CPI (YoY %)', 'US CPI (YoY %)', 'OECD CPI (YoY %)', 'Energy CPI (YoY %)', 'Food CPI (YoY %)']
corr_series = df_merged[features].corrwith(df_merged['Brent Crude ($/bbl)'])

print("Event-based merged data sample:")
print(df_merged[['Date_x', 'Date_y', 'Brent Crude ($/bbl)', 'Energy CPI (YoY %)', 'Global CPI (YoY %)']])
print("\nCorrelation coefficients with Brent Crude:")
print(corr_series)

# Plotting using a clean BLUE color scheme as requested
plt.figure(figsize=(10, 5))
sns.set_theme(style="whitegrid")
# Create a barplot of correlations in sorted order
corr_df = corr_series.reset_index()
corr_df.columns = ['CPI Indicator', 'Correlation Coefficient']
corr_df = corr_df.sort_values(by='Correlation Coefficient', ascending=True)

colors = sns.color_palette("Blues_d", n_colors=len(corr_df))
bars = plt.barh(corr_df['CPI Indicator'], corr_df['Correlation Coefficient'], color=colors, height=0.6, edgecolor='none')

plt.xlim(-1, 1)
plt.axvline(0, color='black', linewidth=1, linestyle='-')
plt.xlabel('Pearson Correlation Coefficient ($r$)', fontsize=12, fontweight='bold')
plt.ylabel('Inflation Metric (YoY %)', fontsize=12, fontweight='bold')
plt.title('Correlation Analysis: Brent Crude Spot Prices vs. Inflation Metrics\nAcross Major Supply Shock Events (1973-2026)', fontsize=13, fontweight='bold', pad=15)

# Add value labels to bars
for bar in bars:
    width = bar.get_width()
    if width < 0:
        plt.text(width - 0.05, bar.get_y() + bar.get_height()/2, f'{width:.3f}', 
                 va='center', ha='right', color='#084594', fontweight='bold', fontsize=10)
    else:
        plt.text(width + 0.05, bar.get_y() + bar.get_height()/2, f'{width:.3f}', 
                 va='center', ha='left', color='#084594', fontweight='bold', fontsize=10)

plt.tight_layout()
plt.savefig('correlation_analysis_blue.png', dpi=300)
print("Plot saved.")

